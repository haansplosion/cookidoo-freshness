# Copy this file to .env and fill in your values
# .env is gitignored and never committed

# Netlify Personal Access Token (from app.netlify.com/user/applications)
NETLIFY_PAT=your_netlify_pat_here

# ── Preferred auth: Cookidoo email + password ─────────────────────────────────
# These are used to get a proper OAuth token via Vorwerk's login endpoint.
# Token is cached and auto-refreshed in Netlify Blobs — no manual cookie needed.
COOKIDOO_EMAIL=your@email.com
COOKIDOO_PASSWORD=your_password_here

# ── Fallback auth: session cookie ─────────────────────────────────────────────
# Only needed if email/password auth doesn't work.
# Get from DevTools → Network → cooking-history request → cookie: header
COOKIDOO_COOKIE=

# Netlify auto-injects SITE_ID in deployed functions — no need to set manually
# SITE_ID=auto-injected
